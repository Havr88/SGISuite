# Configuración del Sistema de Inventario

# Clave secreta para sesiones (Cambiar en producción)
SECRET_KEY=mi-clave-secreta-muy-segura

# URL de la Base de Datos
# Ejemplos:
# SQLite (Local/VPS): Dejar comentado o vacío para usar SQLite por defecto.
# PostgreSQL: postgresql://usuario:password@localhost:5432/nombre_db
# MySQL: mysql+pymysql://usuario:password@localhost:3306/nombre_db

# DATABASE_URL=postgresql://usuario:password@localhost:5432/inventario_db
