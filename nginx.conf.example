# Configuración de Nginx para SGI Suite (Opcional - Reemplazo directo en host)
server {
    listen 80;
    server_name sgi.tudominio.com; # Cambiar por el dominio real

    location / {
        proxy_pass http://127.0.0.0:5000; # Apuntar al puerto expuesto por Docker
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Logging opcional
    error_log /var/log/nginx/sgi_error.log;
    access_log /var/log/nginx/sgi_access.log;
}
